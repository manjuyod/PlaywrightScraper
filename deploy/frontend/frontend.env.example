# Stage as /etc/grade-frontend/frontend.env, owned root:root with mode 0600.
DEPLOYMENT_ENV=production
GRADE_API_BASE_URL=https://grades-api.tutoringclub.com
GRADE_API_CA_FILE=/etc/grade-frontend/pki/api-ca-chain.pem
GRADE_API_CLIENT_CERT_FILE=/etc/grade-frontend/pki/frontend-client.crt
GRADE_API_CLIENT_KEY_FILE=/etc/grade-frontend/pki/frontend-client.key
GRADE_API_TIMEOUT_SECONDS=20
SESSION_SECRET=<from-frontend-secrets-manager>
DASHBOARD_HMAC_SIGNING_SECRET=<from-frontend-secrets-manager>
