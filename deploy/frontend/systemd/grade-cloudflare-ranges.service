[Unit]
Description=Refresh trusted Cloudflare proxy ranges for grade frontend Nginx
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=root
Group=root
ExecStart=/usr/local/lib/grade-boundary/update-cloudflare-ranges
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/etc/nginx/conf.d
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
