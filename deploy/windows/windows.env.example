# Stage through the Windows secret mechanism; never commit populated values.
DEPLOYMENT_ENV=production
GRADE_API_BASE_URL=https://grades-api.tutoringclub.com

WORKER_ID=<windows-worker-identity>
WORKER_API_KEY=<raw-worker-api-key>

SCHEDULER_API_KEY=<raw-scheduler-api-key>
WINDOWS_TARGET_WORKER_ID=<windows-worker-identity>

OPERATOR_API_KEY=<raw-operator-api-key>

# Target deployment uses the Windows trust store and no client certificate.
# Custom CA and complete role client-certificate/key pairs are optional transition compatibility only.

WINDOWS_SCHEDULED_FRANCHISES=6,8,11,15,16,19,49,57,60,74,87
WINDOWS_SCHEDULED_JOB_KINDS=grade,agenda
