# Stage as /etc/grade-api/api.env, owned root:root with mode 0600.
DEPLOYMENT_ENV=production
API_BIND_ADDR=127.0.0.1:3000
NEON_DATABASE_URL=<from-api-secrets-manager>
CRM_DATABASE_URL=<from-api-secrets-manager>
WORKER_API_TOKENS_JSON=<from-api-secrets-manager>
SCHEDULER_API_TOKENS_JSON=<from-api-secrets-manager>
OPERATOR_API_TOKENS_JSON=<from-api-secrets-manager>
WORKER_LEASE_SECONDS=300
DASHBOARD_HMAC_MAX_AGE_SECONDS=60
READINESS_API_TOKEN=<from-api-secrets-manager>
READINESS_TIMEOUT_MILLIS=2000
DASHBOARD_HMAC_ACTIVE_SECRET=<from-api-secrets-manager>
# DASHBOARD_HMAC_PREVIOUS_SECRET is present only during a verifier overlap.
ALTERNATE_CREDENTIAL_ACTIVE_KEY_ID=<current-key-id>
ALTERNATE_CREDENTIAL_KEYS_JSON=<from-api-secrets-manager>
# Set true only between migration 005 and verified migration 006 cutover.
ALLOW_PLAINTEXT_ALTERNATE_CREDENTIALS=true
RUST_LOG=info
